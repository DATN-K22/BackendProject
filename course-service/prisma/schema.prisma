generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "multiSchema"]
  engineType      = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["course_service"]
}

model Course {
  id                BigInt                   @id @default(autoincrement())
  owner_id          String
  title             String                   @db.VarChar(255)
  short_description String?
  long_description  String?
  thumbnail_url     String?                  @db.VarChar(255)
  price             Decimal                  @default(0) @db.Decimal(10, 2)
  status            ContentStatus            @default(draft)
  created_at        DateTime                 @default(now()) @db.Timestamptz(6)
  course_level      CourseLevel              @default(Beginner)
  language          String                   @default("simple")
  rating            Float                    @default(0)
  fts_vector        Unsupported("tsvector")?
  chapters          Chapter[]
  enrollments       Enrollment[]
  forum             Forum?

  @@schema("course_service")
}

model Chapter {
  id          BigInt        @id @default(autoincrement())
  course_id   BigInt?
  resource_id BigInt?
  title       String        @db.VarChar(255)
  status      ContentStatus @default(draft)
  sort_order  Int?
  course      Course?       @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons     Lesson[]
  Quiz        Quiz[]

  @@index([course_id], map: "idx_chapter_course")
  @@schema("course_service")
}

model Lesson {
  id                BigInt         @id @default(autoincrement())
  chapter_id        BigInt
  title             String         @db.VarChar(255)
  short_description String?
  long_description  String?
  thumbnail_url     String?        @db.VarChar(255)
  status            ContentStatus  @default(published)
  sort_order        Int?
  resources         BigInt[]
  type              LessonType     @default(video)
  duration          Float          @default(0)
  chapter           Chapter        @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  lessonStatuses    LessonStatus[]

  @@index([chapter_id], map: "idx_lesson_chapter")
  @@schema("course_service")
}

model Enrollment {
  id               BigInt   @id @default(autoincrement())
  course_id        BigInt
  user_id          String
  enrolled_at      DateTime @default(now()) @db.Timestamptz(6)
  complete_percent Float    @default(0)
  course           Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([user_id, enrolled_at(sort: Desc)], map: "idx_enrollment_user_enrolled")
  @@index([course_id], map: "idx_enrollment_course")
  @@schema("course_service")
}

model LessonStatus {
  id         BigInt   @id @default(autoincrement())
  user_id    String
  lesson_id  BigInt
  updated_at DateTime @default(now()) @db.Timestamptz(6)
  lesson     Lesson   @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id], name: "uq_lesson_status_user_lesson")
  @@index([user_id, updated_at(sort: Desc)], map: "idx_lesson_status_user_updated")
  @@index([lesson_id], map: "idx_lesson_status_lesson")
  @@schema("course_service")
}

model Forum {
  id                BigInt    @id @default(autoincrement())
  course_id         BigInt    @unique
  short_description String?   @db.VarChar(255)
  long_description  String?
  thumbnail_url     String?   @db.VarChar(255)
  course            Course    @relation(fields: [course_id], references: [id], onDelete: Cascade)
  messages          Message[]

  @@schema("course_service")
}

model Message {
  id                BigInt    @id @default(autoincrement())
  forum_id          BigInt
  user_id           String?
  parent_message_id BigInt?
  content           String
  open_time         DateTime? @db.Timestamptz(6)
  closed_time       DateTime? @db.Timestamptz(6)
  status            String    @default("active") @db.VarChar(50)
  created_at        DateTime  @default(now()) @db.Timestamptz(6)
  forum             Forum     @relation(fields: [forum_id], references: [id], onDelete: Cascade)
  parent_message    Message?  @relation("MessageReplies", fields: [parent_message_id], references: [id], onDelete: Cascade)
  replies           Message[] @relation("MessageReplies")

  @@schema("course_service")
}

model Quiz {
  id           BigInt         @id @default(autoincrement())
  title        String         @db.VarChar(255)
  time_limit   Int
  description  String?
  chapter_id   BigInt
  Chapter      Chapter        @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  QuizQuestion QuizQuestion[]
  QuizSession  QuizSession[]

  @@index([chapter_id], map: "idx_quiz_chapter")
  @@schema("course_service")
}

model QuizOption {
  id               BigInt       @id @default(autoincrement())
  quiz_question_id BigInt
  option_text      String
  is_correct       Boolean
  description      String
  QuizQuestion     QuizQuestion @relation(fields: [quiz_question_id], references: [id], onDelete: Cascade)

  @@index([quiz_question_id], map: "idx_quiz_option_question")
  @@schema("course_service")
}

model QuizQuestion {
  id            BigInt       @id @default(autoincrement())
  quiz_id       BigInt
  question_text String
  QuizOption    QuizOption[]
  Quiz          Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([quiz_id], map: "idx_quiz_question_quiz")
  @@schema("course_service")
}

model QuizSession {
  id             BigInt    @id @default(autoincrement())
  quiz_id        BigInt
  user_id        String
  started_at     DateTime  @default(now()) @db.Timestamptz(6)
  ended_at       DateTime? @db.Timestamptz(6)
  finish         Boolean   @default(false)
  rightQuestions Int       @default(0)
  questionOrder  BigInt[]
  Quiz           Quiz      @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([quiz_id], map: "idx_quiz_session_quiz")
  @@index([user_id, started_at(sort: Desc)], map: "idx_quiz_session_user_started")
  @@schema("course_service")
}

enum ContentStatus {
  draft
  published
  archived

  @@schema("course_service")
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
  Expert
  AllLevels

  @@schema("course_service")
}

enum LessonType {
  video
  quiz
  assignment
  lab

  @@schema("course_service")
}
