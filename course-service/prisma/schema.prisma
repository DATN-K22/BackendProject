generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "multiSchema"]
  engineType      = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["course_service"]
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum ContentStatus {
  draft
  published
  archived

  @@schema("course_service")
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
  Expert
  AllLevels

  @@schema("course_service")
}

enum ChapterItemType {
  lesson
  quiz
  lab

  @@schema("course_service")
}

enum SkillLevel {
  basic
  intermediate
  advanced

  @@schema("course_service")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE // future
  FILL_BLANK // future

  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// Course
// ---------------------------------------------------------------------------

model Course {
  id                BigInt                   @id @default(autoincrement())
  owner_id          String
  title             String                   @db.VarChar(255)
  short_description String?                  @db.Text
  long_description  String?                  @db.Text
  thumbnail_url     String?                  @db.VarChar(255)
  price             Decimal                  @default(0) @db.Decimal(10, 2)
  status            ContentStatus            @default(draft)
  created_at        DateTime                 @default(now()) @db.Timestamptz
  course_level      CourseLevel              @default(Beginner)
  rating            Float                    @default(0)
  language          String                   @default("simple")
  fts_vector        Unsupported("tsvector")?

  enrollments Enrollment[]
  chapters    Chapter[]

  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// Chapter
// ---------------------------------------------------------------------------

model Chapter {
  id          BigInt        @id @default(autoincrement())
  course_id   BigInt?
  resource_id BigInt?
  title       String        @db.VarChar(255)
  status      ContentStatus @default(draft)
  sort_order  Int?

  course       Course?       @relation(fields: [course_id], references: [id], onDelete: Cascade)
  chapterItems ChapterItem[]

  @@index([course_id], name: "idx_chapter_course")
  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// ChapterItem — ordering layer, single source of truth for sort_order
// ---------------------------------------------------------------------------

model ChapterItem {
  id         BigInt          @id @default(autoincrement())
  chapter_id BigInt
  item_type  ChapterItemType
  status     ContentStatus   @default(published)
  lesson_id  BigInt?         @unique // XOR enforced via CHECK constraint in migration
  quiz_id    BigInt?         @unique
  lab_id     BigInt?         @unique
  sort_order Int

  chapter             Chapter             @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  lesson              Lesson?             @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  quiz                Quiz?               @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  lab                 Lab?                @relation(fields: [lab_id], references: [id], onDelete: Cascade)
  chapterItemStatuses ChapterItemStatus[]

  @@unique([chapter_id, sort_order], name: "uq_chapter_item_order")
  @@index([chapter_id], name: "idx_chapter_item_chapter")
  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// Lesson — pure content, no sort_order / chapter_id / type
// ---------------------------------------------------------------------------

model Lesson {
  id                BigInt   @id @default(autoincrement())
  title             String   @db.VarChar(255)
  short_description String?  @db.Text
  long_description  String?  @db.Text
  duration          Float    @default(0)
  resources         BigInt[]

  chapterItem ChapterItem?

  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// Lab — pure content, mirrors Lesson structure
// ---------------------------------------------------------------------------

model Lab {
  id                BigInt        @id @default(autoincrement())
  title             String        @db.VarChar(255)
  short_description String?       @db.Text
  long_description  String?       @db.Text
  duration          Float         @default(0)
  leaseTemplateId   String?       @db.VarChar(255)
  resources         BigInt[]

  chapterItem ChapterItem?

  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// ChapterItemStatus — unified completion tracking across all item types
// When a QuizSession finishes → app layer upserts completed = true here too
// ---------------------------------------------------------------------------

model ChapterItemStatus {
  id              BigInt   @id @default(autoincrement())
  user_id         String
  chapter_item_id BigInt
  completed       Boolean  @default(false)
  updated_at      DateTime @default(now()) @db.Timestamptz

  chapterItem ChapterItem @relation(fields: [chapter_item_id], references: [id], onDelete: Cascade)

  @@unique([user_id, chapter_item_id], name: "uq_chapter_item_status_user_item")
  @@index([user_id, updated_at(sort: Desc)], name: "idx_chapter_item_status_user_updated")
  @@index([chapter_item_id], name: "idx_chapter_item_status_item")
  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// Enrollment
// ---------------------------------------------------------------------------

model Enrollment {
  id               BigInt   @id @default(autoincrement())
  course_id        BigInt
  user_id          String
  enrolled_at      DateTime @default(now()) @db.Timestamptz
  complete_percent Float    @default(0)

  course Course @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([user_id, enrolled_at(sort: Desc)], name: "idx_enrollment_user_enrolled")
  @@index([course_id], name: "idx_enrollment_course")
  @@schema("course_service")
}

// ---------------------------------------------------------------------------
// Quiz
// ---------------------------------------------------------------------------

model Quiz {
  id          BigInt  @id @default(autoincrement())
  title       String  @db.VarChar(255)
  description String? @db.Text

  chapterItem    ChapterItem?
  quiz_questions QuizQuestion[]
  quiz_sessions  QuizSession[]

  @@schema("course_service")
}

model QuizQuestion {
  id            BigInt       @id @default(autoincrement())
  quiz_id       BigInt
  question_text String       @db.Text
  questionType  QuestionType @default(SINGLE_CHOICE)

  quiz_options QuizOption[]
  quiz         Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([quiz_id], name: "idx_quiz_question_quiz")
  @@schema("course_service")
}

model QuizOption {
  id               BigInt  @id @default(autoincrement())
  quiz_question_id BigInt
  option_text      String  @db.Text
  is_correct       Boolean
  description      String  @db.Text
  reason           String  @default("") @db.Text

  quizQuestion QuizQuestion @relation(fields: [quiz_question_id], references: [id], onDelete: Cascade)

  @@index([quiz_question_id], name: "idx_quiz_option_question")
  @@schema("course_service")
}

model QuizSession {
  id             BigInt     @id @default(autoincrement())
  quiz_id        BigInt
  user_id        String
  started_at     DateTime   @default(now()) @db.Timestamptz
  ended_at       DateTime?  @db.Timestamptz
  finish         Boolean    @default(false)
  rightQuestions Int        @default(0)
  questionOrder  BigInt[]
  answeredCount  Int        @default(0)
  totalQuestions Int        @default(0)
  skillEstimate  SkillLevel @default(basic)

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([user_id, started_at(sort: Desc)], name: "idx_quiz_session_user_started")
  @@index([quiz_id], name: "idx_quiz_session_quiz")
  @@schema("course_service")
}
