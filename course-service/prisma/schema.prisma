generator client {
  provider        = "prisma-client-js"
  engineType      = "binary"
  previewFeatures = ["multiSchema", "fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["course_service"]
}

enum ContentStatus {
  draft
  published
  archived

  @@schema("course_service")
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
  Expert
  AllLevels

  @@schema("course_service")
}

enum LessonType {
  video
  quiz
  assignment
  lab

  @@schema("course_service")
}

model Course {
  id                BigInt                   @id @default(autoincrement())
  owner_id          String // References user from iam-service
  title             String                   @db.VarChar(255)
  short_description String?                  @db.Text
  long_description  String?                  @db.Text
  thumbnail_url     String?                  @db.VarChar(255)
  price             Decimal                  @default(0) @db.Decimal(10, 2)
  status            ContentStatus            @default(draft)
  created_at        DateTime                 @default(now()) @db.Timestamptz
  course_level      CourseLevel              @default(Beginner)
  rating            Float                    @default(0)
  language          String                   @default("simple")
  fts_vector        Unsupported("tsvector")?
  // Relations
  enrollments       Enrollment[]
  chapters          Chapter[]

  @@schema("course_service")
}

model Chapter {
  id          BigInt        @id @default(autoincrement())
  course_id   BigInt?
  resource_id BigInt?
  title       String        @db.VarChar(255)
  status      ContentStatus @default(draft)
  sort_order  Int?

  // Relations
  course  Course?  @relation(fields: [course_id], references: [id], onDelete: Cascade)
  lessons Lesson[]
  quizzes Quiz[]

  @@index([course_id], name: "idx_chapter_course")
  @@schema("course_service")
}

model Lesson {
  id                BigInt        @id @default(autoincrement())
  chapter_id        BigInt
  title             String        @db.VarChar(255)
  short_description String?       @db.Text
  long_description  String?       @db.Text
  thumbnail_url     String?       @db.VarChar(255) // could be removed
  status            ContentStatus @default(published)
  type              LessonType    @default(video)
  duration          Float         @default(0)
  sort_order        Int?

  // Relations
  chapter        Chapter        @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  resources      BigInt[]
  lessonStatuses LessonStatus[]

  @@index([chapter_id], name: "idx_lesson_chapter")
  @@schema("course_service")
}

model Enrollment {
  id               BigInt   @id @default(autoincrement())
  course_id        BigInt
  user_id          String
  enrolled_at      DateTime @default(now()) @db.Timestamptz
  complete_percent Float    @default(0)
  course           Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([user_id, enrolled_at(sort: Desc)], name: "idx_enrollment_user_enrolled")
  @@index([course_id], name: "idx_enrollment_course")
  @@schema("course_service")
}

model LessonStatus {
  id         BigInt   @id @default(autoincrement())
  user_id    String
  lesson_id  BigInt
  updated_at DateTime @default(now()) @db.Timestamptz

  lesson Lesson @relation(fields: [lesson_id], references: [id], onDelete: Cascade)

  @@unique([user_id, lesson_id], name: "uq_lesson_status_user_lesson")
  @@index([user_id, updated_at(sort: Desc)], name: "idx_lesson_status_user_updated")
  @@index([lesson_id], name: "idx_lesson_status_lesson")
  @@schema("course_service")
}

enum SkillLevel {
  basic
  intermediate
  advanced

  @@schema("course_service")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE // future
  FILL_BLANK // future

  @@schema("course_service")
}

model Quiz {
  id          BigInt  @id @default(autoincrement())
  title       String  @db.VarChar(255)
  description String? @db.Text
  chapter_id  BigInt
  // time_limit removed — learning model has no timer pressure

  chapter        Chapter        @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  quiz_questions QuizQuestion[]
  quiz_sessions  QuizSession[]

  @@index([chapter_id], name: "idx_quiz_chapter")
  @@schema("course_service")
}

model QuizQuestion {
  id            BigInt       @id @default(autoincrement())
  quiz_id       BigInt
  question_text String       @db.Text
  questionType  QuestionType @default(SINGLE_CHOICE) // NEW — extensibility hook

  quiz_options QuizOption[]
  quiz         Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([quiz_id], name: "idx_quiz_question_quiz")
  @@schema("course_service")
}

model QuizOption {
  id               BigInt  @id @default(autoincrement())
  quiz_question_id BigInt
  option_text      String  @db.Text
  is_correct       Boolean
  description      String  @db.Text // kept: detailed explanation for correct answer
  reason           String  @default("") @db.Text // NEW: per-option explanation (right OR wrong)

  quizQuestion QuizQuestion @relation(fields: [quiz_question_id], references: [id], onDelete: Cascade)

  @@index([quiz_question_id], name: "idx_quiz_option_question")
  @@schema("course_service")
}

model QuizSession {
  id             BigInt     @id @default(autoincrement())
  quiz_id        BigInt
  user_id        String
  started_at     DateTime   @default(now()) @db.Timestamptz
  ended_at       DateTime?  @db.Timestamptz
  finish         Boolean    @default(false)
  rightQuestions Int        @default(0)
  questionOrder  BigInt[]
  answeredCount  Int        @default(0) // NEW — avoids scanning questionOrder in Redis
  totalQuestions Int        @default(0) // NEW — denormalised for quick progress %
  skillEstimate  SkillLevel @default(basic) // NEW — rolling skill estimate

  quiz Quiz @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([user_id, started_at(sort: Desc)], name: "idx_quiz_session_user_started")
  @@index([quiz_id], name: "idx_quiz_session_quiz")
  @@schema("course_service")
}
