generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "multiSchema"]
  engineType      = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["course_service"]
}

model Course {
  id                BigInt                   @id @default(autoincrement())
  owner_id          String
  title             String                   @db.VarChar(255)
  short_description String?
  long_description  String?
  thumbnail_url     String?                  @db.VarChar(255)
  price             Decimal                  @default(0) @db.Decimal(10, 2)
  status            ContentStatus            @default(draft)
  created_at        DateTime                 @default(now()) @db.Timestamptz(6)
  course_level      CourseLevel              @default(Beginner)
  language          String                   @default("simple")
  rating            Float                    @default(0)
  fts_vector        Unsupported("tsvector")?
  chapters          Chapter[]
  enrollments       Enrollment[]

  @@schema("course_service")
}

model Chapter {
  id           BigInt        @id @default(autoincrement())
  course_id    BigInt?
  resource_id  BigInt?
  title        String        @db.VarChar(255)
  status       ContentStatus @default(draft)
  sort_order   Int?
  course       Course?       @relation(fields: [course_id], references: [id], onDelete: Cascade)
  chapterItems ChapterItem[]

  @@index([course_id], map: "idx_chapter_course")
  @@schema("course_service")
}

model ChapterItem {
  id         BigInt          @id @default(autoincrement())
  chapter_id BigInt
  item_type  ChapterItemType
  lesson_id  BigInt?         @unique
  quiz_id    BigInt?         @unique
  lab_id     BigInt?         @unique
  sort_order Int

  title             String  @db.VarChar(255)
  short_description String?
  long_description  String?

  duration            Float               @default(0)
  status              ContentStatus       @default(published)
  chapter             Chapter             @relation(fields: [chapter_id], references: [id], onDelete: Cascade)
  lab                 Lab?                @relation(fields: [lab_id], references: [id], onDelete: Cascade)
  lesson              Lesson?             @relation(fields: [lesson_id], references: [id], onDelete: Cascade)
  quiz                Quiz?               @relation(fields: [quiz_id], references: [id], onDelete: Cascade)
  chapterItemStatuses ChapterItemStatus[]

  @@unique([chapter_id, sort_order], name: "uq_chapter_item_order")
  @@index([chapter_id], map: "idx_chapter_item_chapter")
  @@schema("course_service")
}

model Lesson {
  id          BigInt       @id @default(autoincrement())
  resources   BigInt[]
  is_free     Boolean      @default(false)
  chapterItem ChapterItem?

  @@schema("course_service")
}

model Lab {
  id              BigInt       @id @default(autoincrement())
  leaseTemplateId String?      @db.VarChar(255)
  resources       BigInt[]
  instruction     String?
  chapterItem     ChapterItem?

  @@schema("course_service")
}

model ChapterItemStatus {
  id              BigInt      @id @default(autoincrement())
  user_id         String
  chapter_item_id BigInt
  completed       Boolean     @default(false)
  updated_at      DateTime    @default(now()) @db.Timestamptz(6)
  chapterItem     ChapterItem @relation(fields: [chapter_item_id], references: [id], onDelete: Cascade)

  @@unique([user_id, chapter_item_id], name: "uq_chapter_item_status_user_item")
  @@index([user_id, updated_at(sort: Desc)], map: "idx_chapter_item_status_user_updated")
  @@index([chapter_item_id], map: "idx_chapter_item_status_item")
  @@schema("course_service")
}

model Enrollment {
  id               BigInt   @id @default(autoincrement())
  course_id        BigInt
  user_id          String
  enrolled_at      DateTime @default(now()) @db.Timestamptz(6)
  complete_percent Float    @default(0)
  course           Course   @relation(fields: [course_id], references: [id], onDelete: Cascade)

  @@index([user_id, enrolled_at(sort: Desc)], map: "idx_enrollment_user_enrolled")
  @@index([course_id], map: "idx_enrollment_course")
  @@schema("course_service")
}

model Quiz {
  id             BigInt         @id @default(autoincrement())
  chapterItem    ChapterItem?
  quiz_questions QuizQuestion[]
  quiz_sessions  QuizSession[]

  @@schema("course_service")
}

model QuizQuestion {
  id            BigInt       @id @default(autoincrement())
  quiz_id       BigInt
  question_text String
  questionType  QuestionType @default(SINGLE_CHOICE)
  quiz_options  QuizOption[]
  quiz          Quiz         @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([quiz_id], map: "idx_quiz_question_quiz")
  @@schema("course_service")
}

model QuizOption {
  id               BigInt       @id @default(autoincrement())
  quiz_question_id BigInt
  option_text      String
  is_correct       Boolean
  description      String
  reason           String       @default("")
  quizQuestion     QuizQuestion @relation(fields: [quiz_question_id], references: [id], onDelete: Cascade)

  @@index([quiz_question_id], map: "idx_quiz_option_question")
  @@schema("course_service")
}

model QuizSession {
  id             BigInt     @id @default(autoincrement())
  quiz_id        BigInt
  user_id        String
  started_at     DateTime   @default(now()) @db.Timestamptz(6)
  ended_at       DateTime?  @db.Timestamptz(6)
  finish         Boolean    @default(false)
  rightQuestions Int        @default(0)
  questionOrder  BigInt[]
  answeredCount  Int        @default(0)
  skillEstimate  SkillLevel @default(basic)
  totalQuestions Int        @default(0)
  quiz           Quiz       @relation(fields: [quiz_id], references: [id], onDelete: Cascade)

  @@index([user_id, started_at(sort: Desc)], map: "idx_quiz_session_user_started")
  @@index([quiz_id], map: "idx_quiz_session_quiz")
  @@schema("course_service")
}

enum ContentStatus {
  draft
  published
  archived

  @@schema("course_service")
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
  Expert
  AllLevels

  @@schema("course_service")
}

enum ChapterItemType {
  lesson
  quiz
  lab

  @@schema("course_service")
}

enum SkillLevel {
  basic
  intermediate
  advanced

  @@schema("course_service")
}

enum QuestionType {
  SINGLE_CHOICE
  MULTI_CHOICE
  FILL_BLANK

  @@schema("course_service")
}