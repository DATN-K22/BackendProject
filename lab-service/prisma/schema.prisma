generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
  engineType      = "binary"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["lab_service"]
}

// ============================================================
// Enums
// ============================================================

enum LabType {
  ec2
  s3
  lambda
  database

  @@schema("lab_service")
}

enum LabMode {
  tutorial
  challenge

  @@schema("lab_service")
}

enum LabSessionStatus {
  provisioning
  ready // User đang làm
  finished // User bấm finish
  expired // Hết giờ
  failed // Lỗi khi provision

  @@schema("lab_service")
}

// ============================================================
// Lab — metadata, gắn với lesson_id bên course_service
// ============================================================

model Lab {
  id        BigInt  @id @default(autoincrement())
  lesson_id BigInt  @unique // FK sang course_service, không dùng relation
  lab_type  LabType

  // CloudFormation scripts
  tutorial_cfn_script  String? @db.Text // setup sẵn tài nguyên cho user theo dõi
  challenge_cfn_script String? @db.Text // setup môi trường, user tự hoàn thành

  // Nội dung hướng dẫn hiển thị trong lab
  tutorial_instructions  String? @db.Text
  challenge_instructions String? @db.Text

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  // Relations
  sessions LabSession[]

  @@schema("lab_service")
}

// ============================================================
// LabSession — mỗi lần user bắt đầu làm lab = 1 session
// ============================================================

model LabSession {
  id      BigInt           @id @default(autoincrement())
  lab_id  BigInt
  user_id String // FK sang iam_service
  mode    LabMode
  status  LabSessionStatus @default(provisioning)

  // AWS info
  aws_account_id   String @db.VarChar(20) // e.g. 416170614721
  aws_role_arn     String @db.VarChar(255)
  aws_session_name String @db.VarChar(255) // dùng để tra CloudTrail

  // Thời gian
  started_at  DateTime  @default(now()) @db.Timestamptz
  expires_at  DateTime  @db.Timestamptz // started_at + duration của mode
  finished_at DateTime? @db.Timestamptz // null nếu expired hoặc failed

  // Challenge mode only
  score     Int? // 0-100
  is_passed Boolean?

  // Relations
  lab Lab @relation(fields: [lab_id], references: [id], onDelete: Cascade)

  @@index([user_id, started_at(sort: Desc)], name: "idx_lab_session_user")
  @@index([lab_id], name: "idx_lab_session_lab")
  @@index([status], name: "idx_lab_session_status")
  @@schema("lab_service")
}

// ============================================================
// LabAccount — pool các AWS account dùng cho lab
// ============================================================

enum LabAccountStatus {
  available
  in_use
  cleanup
  error

  @@schema("lab_service")
}

model LabAccount {
  id                  BigInt           @id @default(autoincrement())
  account_id          String           @unique @db.VarChar(20) // AWS account ID
  role_arn            String           @db.VarChar(255) // role để assume vào account này
  status              LabAccountStatus @default(available)
  assigned_session_id BigInt? // LabSession đang dùng account này

  last_cleanup_at DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz

  @@index([status], name: "idx_lab_account_status")
  @@schema("lab_service")
}
