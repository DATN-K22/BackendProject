// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider        = "prisma-client"
  previewFeatures = ["multiSchema"]
  output          = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["media_service"]
}

enum ResourceType {
  video
  document
  image

  @@schema("media_service")
}

model Resource {
  id    BigInt       @id @default(autoincrement())
  title String       @db.VarChar(255)
  type  ResourceType

  thumb        String? @db.VarChar(500) // Can be removed
  link         String? @db.VarChar(500) // Can be removed
  manifest_url String? @db.VarChar(500) // Can be removed

  path     String @db.VarChar(255)
  filename String @db.VarChar(255)

  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz
  lesson_id  BigInt?

  // Relations
  watching_progress WatchingProgress[]

  @@schema("media_service")
}

model WatchingProgress {
  user_id     String
  resource_id BigInt
  is_opened   Boolean   @default(false)
  last_watch  DateTime? @db.Timestamptz

  // Relations
  resource Resource @relation(fields: [resource_id], references: [id], onDelete: Cascade)

  @@id([user_id, resource_id])
  @@schema("media_service")
}

model PaymentRecord {
  id          String        @id @default(uuid())
  orderCode   String        @unique
  userId      String
  courseId    String
  status      PaymentStatus @default(PENDING)
  amount      Int
  description String?
  buyerEmail  String?
  buyerName   String?
  rawWebhook  Json?
  paidAt      DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  enrollJobs EnrollJob[]

  @@schema("media_service")
}

model EnrollJob {
  id            String    @id @default(uuid())
  paymentId     String
  status        JobStatus @default(PENDING)
  attemptCount  Int       @default(0)
  lastAttemptAt DateTime?
  lastError     String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payment PaymentRecord @relation(fields: [paymentId], references: [id])

  @@schema("media_service")
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  FAILED

  @@schema("media_service")
}

enum JobStatus {
  PENDING
  DONE
  DEAD

  @@schema("media_service")
}
