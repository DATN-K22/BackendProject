{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2021",
    "outDir": "./dist",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,                   
    "esModuleInterop": true,         
    "types": ["node", "jest"]         
  },
  "include": ["src/**/*", "test/**/*"],
  "exclude": ["node_modules"]
}